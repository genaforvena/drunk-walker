{
  "manifest_version": 3,
  "name": "Drunk Walker",
  "version": "3.1.0-exp",
  "description": "Automated chaotic Street View navigation using cursor-relative clicks.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://maps.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Drunk Walker"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [{
    "matches": ["https://www.google.com/maps/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "browser_specific_settings": {
    "gecko": {
      "id": "drunk-walker-chaos@genaforvena.github.io",
      "strict_min_version": "109.0"
    }
  }
}
